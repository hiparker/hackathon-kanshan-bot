VITE_OPENAI_BASE_URL=
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=
# SecondMe Lab 流式分身对话（OpenAI 兼容响应 SSE；需 OAuth scope chat，Bearer 为 lba_at_...）
# 设为 1 时：请求体改为 SecondMe 格式，Vite 将 /proxy-openai/* 转发到 .../api/secondme/chat/stream
VITE_SECONDME_CHAT=
# 可选：固定使用 Lab 基地址时可省略 VITE_OPENAI_BASE_URL
# VITE_OPENAI_BASE_URL=https://api.mindverse.com/gate/lab
VITE_SECONDME_APP_ID=
VITE_SECONDME_MAX_TOKENS=
VITE_SECONDME_WEB_SEARCH=
VITE_CHAT_USE_MOCK=false
VITE_KANSHAN_API_BASE_URL=http://localhost:8787
VITE_KANSHAN_AUTH_MODE=mock
VITE_KANSHAN_AUTH_CODE=local-dev

# Web 端 GLB HTTPS 地址（非桌面构建；不设则 url 为空，生产部署请必选填）
VITE_KANSHAN_MODEL_WEB_URL=
