PORT=8787
DB_PATH=./kanshan.db
LOG_LEVEL=info
KANSHAN_DEBUG_MODE=false
MARKET_WS_PUSH_INTERVAL_SEC=60
MARKET_WEATHER_CITY=Beijing
# 可选：覆盖默认公开数据源，便于本地联调/测试
MARKET_WEATHER_BASE_URL=
MARKET_CRYPTO_URL=
MARKET_GOLD_URL=
MARKET_INDEX_URL=
MARKET_DAILY_NEWS_URL=
MARKET_HOT_NEWS_URL=
# 知乎社区真实讨论热榜接口（/openapi/billboard/list），需填完整 URL 和鉴权参数；不要提交真实值
MARKET_ZHIHU_HOT_APP_KEY=
MARKET_ZHIHU_HOT_APP_SECRET=
MARKET_ZHIHU_HOT_EXTRA_INFO=
MARKET_ZHIHU_HOT_TOP_CNT=50
MARKET_ZHIHU_HOT_PUBLISH_IN_HOURS=48
ZHIHU_OAUTH_CLIENT_ID=
ZHIHU_OAUTH_CLIENT_SECRET=
ZHIHU_OAUTH_REDIRECT_URI=
ZHIHU_OAUTH_AUTHORIZE_URL=https://openapi.zhihu.com/authorize
ZHIHU_OAUTH_TOKEN_URL=https://openapi.zhihu.com/access_token
ZHIHU_OAUTH_USER_INFO_URL=https://openapi.zhihu.com/user
ZHIHU_OAUTH_SCOPE=

# Frontend dev default uses mock login. Set VITE_KANSHAN_AUTH_MODE=oauth to force real OAuth.
VITE_KANSHAN_AUTH_MODE=mock
VITE_KANSHAN_AUTH_CODE=local-dev

# MCP secondme_user_info 转发 SecondMe Lab（可选覆盖默认 https://api.mindverse.com/gate/lab）
SECONDME_LAB_BASE_URL=
