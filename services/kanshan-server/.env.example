PORT=8787
DB_PATH=./kanshan.db
LOG_LEVEL=info
KANSHAN_DEBUG_MODE=false
MARKET_WS_PUSH_INTERVAL_SEC=60
MARKET_WEATHER_CITY=Beijing
# 可选：覆盖默认公开数据源，便于本地联调/测试
MARKET_WEATHER_BASE_URL=
MARKET_CRYPTO_URL=
MARKET_GOLD_URL=
MARKET_INDEX_URL=
MARKET_DAILY_NEWS_URL=
MARKET_HOT_NEWS_URL=
# 知乎：Bearer 时走 developer.zhihu.com hot_list（Limit + X-Request-Timestamp）；否则 OpenAPI billboard 需 APP_KEY + APP_SECRET
# MARKET_ZHIHU_HOT_BEARER=
MARKET_ZHIHU_HOT_LIST_LIMIT=10
# 热榜本地缓存：秒，默认 300；MARKET_ZHIHU_HOT_CACHE_FILE 未设置时写到用户缓存目录 kanshan-server/zhihu-hot-list-cache.json
MARKET_ZHIHU_HOT_CACHE_SEC=300
MARKET_ZHIHU_HOT_CACHE_FILE=
MARKET_ZHIHU_HOT_URL=
MARKET_ZHIHU_HOT_APP_KEY=
MARKET_ZHIHU_HOT_EXTRA_INFO=
MARKET_ZHIHU_HOT_TOP_CNT=50
MARKET_ZHIHU_HOT_PUBLISH_IN_HOURS=48
# 与 kanshan/backend Python 热榜技能共用 Bearer 时可填
ZHIHU_SECRET=
ZHIHU_OAUTH_CLIENT_ID=
ZHIHU_OAUTH_CLIENT_SECRET=
ZHIHU_OAUTH_REDIRECT_URI=
ZHIHU_OAUTH_AUTHORIZE_URL=https://openapi.zhihu.com/authorize
ZHIHU_OAUTH_TOKEN_URL=https://openapi.zhihu.com/access_token
ZHIHU_OAUTH_USER_INFO_URL=https://openapi.zhihu.com/user
ZHIHU_OAUTH_SCOPE=

# Frontend dev default uses mock login. Set VITE_KANSHAN_AUTH_MODE=oauth to force real OAuth.
VITE_KANSHAN_AUTH_MODE=mock
VITE_KANSHAN_AUTH_CODE=local-dev

# MCP secondme_user_info 转发 SecondMe Lab（可选覆盖默认 https://api.mindverse.com/gate/lab）
SECONDME_LAB_BASE_URL=

# 知乎模型服务。真实 ZHIHU_CHAT_ACCESS_SECRET 只放本地 .env.local 或部署环境，不提交仓库。
ZHIHU_CHAT_COMPLETIONS_URL=https://developer.zhihu.com/v1/chat/completions
ZHIHU_CHAT_MODEL=zhida-fast-1p5
ZHIHU_CHAT_TIMEOUT_SEC=45
ZHIHU_CHAT_MERGE_SYSTEM_TO_USER=true
ZHIHU_CHAT_HISTORY_LIMIT=10
ZHIHU_CHAT_ACCESS_SECRET=
