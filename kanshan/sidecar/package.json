{
  "name": "kanshan-sidecar",
  "version": "0.1.0",
  "private": true,
  "description": "刘看山 Node.js Sidecar：运行 Claude Agent SDK / Claude Code CLI，统一 Agent 会话生命周期 + MCP 工具集成",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.139",
    "@hono/node-server": "^1.13.0",
    "dotenv": "^16.4.5",
    "hono": "^4.6.0",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
