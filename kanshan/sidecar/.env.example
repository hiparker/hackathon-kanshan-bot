# ========= 服务 =========
SIDECAR_PORT=8788
SIDECAR_HOST=0.0.0.0

# ========= Kimi API（兼容 Anthropic 协议） =========
# Kimi Code API（兼容 Anthropic Messages API）
ANTHROPIC_API_KEY=
# Kimi 兼容 Anthropic 协议的地址
ANTHROPIC_BASE_URL=https://api.kimi.com/coding
# 模型 ID（固定值，后端自动更新）
CLAUDE_MODEL=kimi-for-coding

# ========= 运行模式 =========
# sdk  = 使用 @anthropic-ai/claude-agent-sdk（推荐）
# cli  = 使用已安装的 claude CLI 二进制（spawn 子进程）
AGENT_RUNTIME=sdk

# ========= 行为 =========
# UI 权限策略：auto （→acceptEdits）| plan | fullAgency （→bypassPermissions）| custom （→default）
# 也兼容 SDK 原生名：acceptEdits / plan / bypassPermissions / default
PERMISSION_MODE=auto
# 默认工作目录（Agent 读写文件的根）
AGENT_CWD=./workspace
# 会话 / 事件 JSONL 持久化目录
SIDECAR_DATA_DIR=./data
# 默认允许的工具（用逗号分隔，留空＝允许全部）
# 例：Bash,Read,Write,Edit,mcp__weather__get_city_weather
# MCP 工具命名约定：mcp__<server-id>__<tool-name>
ALLOWED_TOOLS=

# ========= MCP =========
MCP_CONFIG_PATH=./mcp.json

# ========= 访问控制 =========
# 供 Python 后端调用时鉴权。留空表示不校验
SIDECAR_TOKEN=
