# ========= 服务 =========
PORT=8787
HOST=0.0.0.0

# ========= 数据库 =========
DB_PATH=./data/kanshan.db

# ========= 配置文件 =========
CONFIG_PATH=./config/config.json

# ========= LLM（OpenAI 兼容协议） =========
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_SUMMARY_MODEL=

# ========= 第三方 Skill =========
# 高德天气 key（https://lbs.amap.com），留空则走 wttr.in
AMAP_KEY=

# 管理员 Token
ADMIN_TOKEN=change-me-please

# ========= Claude Sidecar =========
# sidecar HTTP 地址
SIDECAR_BASE_URL=http://127.0.0.1:8788
# 与 sidecar .env 的 SIDECAR_TOKEN 一致；空 = 不鉴权
SIDECAR_TOKEN=
# 由 Python lifespan 自动拉起 sidecar 子进程（0/1）
SIDECAR_AUTOSPAWN=0
# sidecar 项目目录（相对 backend/ 的路径或绝对路径）
SIDECAR_CWD=../sidecar
# 拉起 sidecar 用的命令
SIDECAR_CMD=npm run dev
